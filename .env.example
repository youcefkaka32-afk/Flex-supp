### Example environment variables for local development
# Copy this file to `.env.local` or `.env` and fill in real values.
# NEVER commit real secrets.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin PIN used by the admin panel (optional — default in code is '1234')
VITE_ADMIN_PIN=1234

# Optional extras (uncomment and set if used)
# VITE_API_URL=https://api.example.com
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Chatbase (optional)
# Set this to the Chatbase bot id to enable the widget. Leave unset to disable.
VITE_CHATBASE_BOT_ID=sHaahB1RfteTCk55rvx1L
# When `VITE_CHATBASE_AUTOLOAD=true` the widget will open automatically after a short delay.
# VITE_CHATBASE_AUTOLOAD=false
